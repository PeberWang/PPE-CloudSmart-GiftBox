# PPE云端智能大礼包环境变量配置
# 复制此文件为.env并填入实际值

# ==================== 飞书应用配置 ====================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
# 文档链接前缀（企业部署改为 xxx.feishu.cn）
FEISHU_DOC_HOST=feishu.cn

# ==================== LLM 配置（DeepSeek，OpenAI 兼容）====================
LLM_API_KEY=sk-your_deepseek_key_here
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-pro

# ==================== OCR 配置（智谱 GLM-OCR）====================
GLM_API_KEY=your_zhipu_api_key_here
GLM_OCR_URL=https://open.bigmodel.cn/api/paas/v4/layout_parsing

# ==================== 云盘 / 摘要存储 ====================
# 云盘后端：local_stub（本地占位）| aliyun_oss
CLOUD_DRIVE_BACKEND=local_stub
CLOUD_STUB_DIR=./cloud_stub
SUMMARY_DIR=./data/summaries

# 阿里云 OSS 配置（cloud_drive_backend=aliyun_oss 时需填写）
OSS_BUCKET=ppe-giftbox
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_key_id
OSS_ACCESS_KEY_SECRET=your_oss_key_secret
OSS_PRESIGNED_TTL=86400
# 认证模式：access_key（个人AK/SK直连）| ram_role（企业AssumeRole+STS临时凭证）
OSS_AUTH_MODE=access_key
# RAM Role ARN（auth_mode=ram_role 时填写，access_key 模式留空即可）
OSS_ROLE_ARN=
OSS_ROLE_SESSION_NAME=ppe-giftbox-deploy
# CDN 域名（企业交付时填写，如 cdn.ppe.nankai.edu.cn；留空则使用预签名 URL）
OSS_CDN_DOMAIN=

# ==================== 路径配置 ====================
# 本地资料包根目录（用于上传的源文件）
MATERIALS_BASE=./data/courses

# 教改笔记目录（用于生成学习指南）
COURSE_REFORM_NOTES_DIR=./data/course_reform_notes

# ==================== 知识库配置 ====================
# 知识空间名称
WIKI_SPACE_NAME=Demo PPE CloudSmart Giftbox

# ==================== 多维表格配置 ====================
# 多维表格App Token（可选，将在运行时创建）
BITABLE_APP_TOKEN=

# ==================== 日志配置 ====================
# 日志级别
LOG_LEVEL=INFO

# 是否输出到文件
LOG_TO_FILE=true
LOG_FILE_PATH=./logs/app.log
